# ============================
# Client-side variables (VITE_ prefix - bundled into the app)
# ============================

# TMDB API Key for film data
# Get yours at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Google Books API Key (optional - works without it)
# VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Mapbox for travel map
# Get a free token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Buzzsprout for Rough Cut audio hosting
# Get your podcast ID from your Buzzsprout dashboard URL
VITE_BUZZSPROUT_PODCAST_ID=your_podcast_id_here

# ============================
# Server-side variables (Vercel serverless functions - NOT exposed to client)
# Set these in Vercel Dashboard > Settings > Environment Variables
# ============================

# GitHub API for admin panel (commits changes directly to repo)
# Create a personal access token at: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=yourusername/yourrepo

# Admin panel password
ADMIN_PASSWORD=your_secure_password_here

# Buttondown for newsletter subscriptions
# Get your API key at: https://buttondown.email/settings
BUTTONDOWN_API_KEY=your_buttondown_api_key_here

# ============================
# Local development overrides (optional)
# Use VITE_ prefix versions below ONLY for local dev without Vercel CLI
# ============================
# VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# VITE_GITHUB_REPO=yourusername/yourrepo
# VITE_ADMIN_PASSWORD=your_secure_password_here
